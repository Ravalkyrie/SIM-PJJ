rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email.matches('.*@pupr\\.go\\.id$');
    }
    
    // Kontrak Collection Rules
    match /kontrak/{contractId} {
      // Allow read for all authenticated users
      allow read: if isSignedIn();
      
      // Allow write only for admin users
      allow create, update: if isAdmin();
      
      // Allow delete only for admin users with extra confirmation
      allow delete: if isAdmin();
    }
    
    // Activity Logs Collection Rules
    match /activity_logs/{logId} {
      // Allow read for all authenticated users
      allow read: if isSignedIn();
      
      // Allow create for authenticated users (auto-logging)
      allow create: if isSignedIn();
      
      // Prevent update and delete of logs (audit trail)
      allow update, delete: if false;
    }
    
    // User Profile Collection (optional - untuk fitur masa depan)
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Users can update their own profile
      allow update: if isSignedIn() && request.auth.uid == userId;
      
      // Only admin can create user profiles
      allow create: if isAdmin();
      
      // Only admin can delete user profiles
      allow delete: if isAdmin();
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
